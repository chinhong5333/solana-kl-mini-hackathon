# Copy to .env.local. Never commit real secrets (.env*.local is gitignored).
# Public vars must be prefixed NEXT_PUBLIC_ to reach the browser.

NEXT_PUBLIC_APP_NAME=SolSplit

# Solana devnet RPC. Falls back to the public endpoint (api.devnet.solana.com,
# heavily rate-limited) if unset. Set a dedicated provider (e.g. Helius) for
# throughput. Read identically by:
#   web  -> .env.local (auto-loaded by Next) / Vercel project env
#   CLI  -> .env.local (npm run cli loads it via --env-file-if-exists)
#   MCP  -> .env.local (npm run mcp / .mcp.json load it via --env-file-if-exists)
SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Production (Vercel) only ---
# Vercel KV (Upstash Redis) credentials. When absent, wallet state + keypairs
# fall back to local JSON files under data/kv/ so `npm run dev` works with zero
# setup. Set both in the Vercel project to enable real cross-instance storage.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Required when KV is configured: encrypts wallet secret keys at rest (AES-256-GCM).
# WALLET_MASTER_KEY=

# Device id the CLI / local non-web callers use (default "local").
# WALLET_DEVICE_ID=local
# Device id the HTTP MCP endpoint (/api/mcp) provisions and operates as (default "mcp").
# MCP_DEVICE_ID=mcp
