# Copy to .env and fill in. The real .env is gitignored — never commit secrets.
#   cp .env.example .env

# Your funded devnet wallet, base58 private key (Phantom: Settings -> Export Private Key).
# No quotes. REQUIRED.
PRIVATE_KEY=

# RPC endpoint. Leave empty for public devnet (https://api.devnet.solana.com).
# Public RPC is rate-limited; for reliability use a Helius/QuickNode/Alchemy devnet URL.
RPC_URL=

# Token mint to split. Devnet USDC shown. Leave empty to create a throwaway test mint.
MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Receiver wallet addresses. Leave empty to use throwaway random wallets.
# Funds go to each receiver's associated token account for MINT (auto-created).
RECEIVER_A=
RECEIVER_B=

# Split amounts in BASE UNITS (USDC has 6 decimals).
# 0.08 USDC = 80000 -> receiver A ; 0.02 USDC = 20000 -> receiver B
AMOUNT1=80000
AMOUNT2=20000
